{
  "family": "hire-me-remotely-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],

  "cpu": "512",
  "memory": "1024",

  "executionRoleArn": "arn:aws:iam::985682977618:role/ecsTaskExecutionRole",

  "containerDefinitions": [
    {
      "name": "api-server",

      "image": "985682977618.dkr.ecr.us-east-1.amazonaws.com/hire-me-remotely-api-server:latest",

      "essential": true,

      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],

      "environment": [
        { "name": "NODE_ENV",   "value": "production" },
        { "name": "PORT",       "value": "3000" },
        { "name": "AWS_REGION", "value": "us-east-1" }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/hire-me-remotely-api",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group":  "true"
        }
      },

      "healthCheck": {
        "command":     ["CMD-SHELL", "wget -qO- http://localhost:3000/api/healthz || exit 1"],
        "interval":    30,
        "timeout":     5,
        "retries":     3,
        "startPeriod": 15
      }
    }
  ]
}
