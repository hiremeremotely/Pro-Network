{
  "manifest_version": 3,
  "name": "Hire Me Remotely",
  "short_name": "HMR",
  "version": "1.0.0",
  "description": "Automatically log job applications to your Hire Me Remotely tracker while you apply on LinkedIn, Indeed, Glassdoor, and more.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Hire Me Remotely",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.replit.dev/*", "*://localhost/*", "*://127.0.0.1/*"],
      "js": ["content/hmr-session.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.linkedin.com/*", "*://linkedin.com/*"],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.indeed.com/*", "*://indeed.com/*"],
      "js": ["content/indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.glassdoor.com/*", "*://glassdoor.com/*"],
      "js": ["content/glassdoor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://wellfound.com/*", "*://www.wellfound.com/*", "*://angel.co/*"],
      "js": ["content/wellfound.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/generic.js"],
      "run_at": "document_idle",
      "exclude_matches": [
        "*://www.linkedin.com/*",
        "*://linkedin.com/*",
        "*://www.indeed.com/*",
        "*://indeed.com/*",
        "*://www.glassdoor.com/*",
        "*://glassdoor.com/*",
        "*://wellfound.com/*",
        "*://www.wellfound.com/*",
        "*://angel.co/*",
        "*://*.replit.dev/*",
        "*://localhost/*",
        "*://127.0.0.1/*",
        "*://chrome.google.com/*",
        "*://chromewebstore.google.com/*"
      ]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.replit.dev/*",
    "*://localhost/*",
    "*://127.0.0.1/*",
    "*://www.linkedin.com/*",
    "*://linkedin.com/*",
    "*://www.indeed.com/*",
    "*://indeed.com/*",
    "*://www.glassdoor.com/*",
    "*://glassdoor.com/*",
    "*://wellfound.com/*",
    "*://www.wellfound.com/*",
    "*://angel.co/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
